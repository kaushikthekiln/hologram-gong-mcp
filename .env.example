# Cloudflare (used by wrangler CLI for deploys; not used at Worker runtime)
CLOUDFLARE_API_TOKEN=cfat_xxx_your_account_owned_token
CLOUDFLARE_ACCOUNT_ID=xxx_32_char_hex_account_id

# Supabase Postgres connection string (read-only role, supavisor pooler URL)
# Set this as a Worker secret: wrangler secret put DATABASE_URL
DATABASE_URL=postgres://gong_mcp_reader.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Google OAuth credentials (Web Application type, created in Google Cloud Console)
# Set as Worker secrets: wrangler secret put GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# Cookie encryption key (any 32-byte hex string)
# Generate: openssl rand -hex 32
# Set as Worker secret: wrangler secret put COOKIE_ENCRYPTION_KEY
COOKIE_ENCRYPTION_KEY=xxx_64_char_hex

# Optional, for the backfill script (Python):
# Hologram Gong API basic auth header (base64 of "access_key:secret")
GONG_BASIC_AUTH=xxx_base64_encoded
# Supabase Management API token (for the backfill script to upsert)
SUPABASE_MGMT_TOKEN=sbp_xxx
SUPABASE_PROJECT_REF=xxx_project_ref
